# Server
PORT=3000

# API Authentication
API_KEY=your-secret-api-key-here

# IP Whitelist (comma-separated, leave empty to allow all)
# Set this to your Digital Ocean droplet's IP
ALLOWED_IPS=123.45.67.89

# Batch Operations
# Delay between each operation in a batch (milliseconds)
# Prevents overwhelming the router — increase for slower hardware
BATCH_DELAY_MS=200

# MikroTik RouterOS
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=billing-api
MIKROTIK_PASSWORD=your-router-password
